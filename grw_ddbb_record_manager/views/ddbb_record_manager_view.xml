<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="ddbb_record_manager_view_form" model="ir.ui.view">
            <field name="name">ddbb.record.manager.view.form</field>
            <field name="model">ddbb.record.manager</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Actualizar Data" name="action_write_model_data" type="object" class="oe_highlight"
                            confirm="¿Esta seguro que desea modificar los datos?"
                            invisible="type_action != 'write'"
                        />
                        <button string="Eliminar Data" name="action_delete_models_data" type="object" class="oe_highlight"
                            confirm="¿Esta seguro que desea eliminar los datos?"
                            invisible="type_action != 'delete'"
                        />
                    </header>
                    <sheet>
                        <group>
                            <field name="model" invisible="1"/>
                            <field name="type_action" widget="selection_badge"/>
                            <field name="data_model"
                                invisible="type_action != 'delete'"
                                options="{'no_create': True, 'no_edit': True}"
                            />
                            <field name="model_id"
                                invisible="type_action != 'write'"
                                options="{'no_create': True, 'no_edit': True}"
                            />
                            <field name="model_ids" widget="many2many_tags" 
                                invisible="type_action != 'delete'"
                                options="{'no_create': True, 'no_edit': True}"
                            />
                            <field name="filter_domain" widget="domain" options="{'model': 'model', 'in_dialog': True}"
                                invisible="model_id == False"
                            />
                            <field name="ddbb_manager_field_ids"
                                invisible="type_action != 'write'"/>
                        </group>
                        <div class="info">
                           <strong>Tipos de Datos soportados:<br/></strong>
                           - Integer<br/>
                           - Float: Separar con coma o punto.<br/>
                           - Char<br/>
                           - Text<br/>
                           - Selection: Ingresar el valor codigo.<br/>
                           - Date: Formato YYYYMMDD, YYYY/MM/DD o YYYY-MM-DD<br/>
                           - Datetime: Formato YYYYMMDD, YYYY/MM/DD o YYYY-MM-DD<br/>
                           - Boolean: True or False<br/>
                           - Many2One, One2Many, Many2Many: Ingresar el ID a vincular.<br/>
                           - Valores de Referencia: Ingresar record.nombre_campo
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ddbb_record_manager_field_view_tree" model="ir.ui.view">
            <field name="name">ddbb.record.manager.field.view.tree</field>
            <field name="model">ddbb.record.manager.field</field>
            <field name="arch" type="xml">
                <tree string="Campos" editable="top">
                    <field name="field"
                        domain="[('model','=',parent.model)]"
                        options="{'no_create': True, 'no_edit': True}"
                    />
                    <field name="field_value"/>
                </tree>
            </field>
        </record>

        <record id="action_ddbb_record_manager" model="ir.actions.act_window">
            <field name="name">Records Manager</field>
            <field name="res_model">ddbb.record.manager</field>
            <field name="view_mode">form</field>
        </record>

        <menuitem
            id="grw_ddbb_record_manager.ddbb_record_manager_menu"
            name="Records Manager"
            parent="base.menu_administration"
            action="grw_ddbb_record_manager.action_ddbb_record_manager"
            groups="base.group_no_one"
            sequence="10"/>

    </data>
</odoo>
